#secret key to sign the session ID cookie
SESSION_SECRET = Your session secret here

#MySQL credentials
DB_HOST = Your DB host here
DB_USER =  Your DB username here
DB_PASSWORD = Your DB passowrd here
DB_NAME = Your DB name here

#Google OAuth credentials
GOOGLE_CLIENT_ID = Your Google client ID here
GOOGLE_CLIENT_SECRET = Your Google client secret here
GOOGLE_REDIRECT_URI = Your Google redirect URI here
GOOGLE_REFRESH_TOKEN = Your Google refresh token here